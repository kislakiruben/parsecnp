{
  "name": "parsecnp",
  "version": "0.1.9",
  "description": "'Parser' pentru cod numeric personal (CNP)",
  "main": "dist/ParseCNP.min.js",
  "scripts": {
    "build": "rollup --config rollup.config.mjs",
    "dev": "rollup --config rollup.config.dev.mjs --watch",
    "test": "TZ='Europe/London' vitest run",
    "coverage": "TZ='Europe/London' vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepare": "pnpm build"
  },
  "types": "src/ParseCNP.js",
  "repository": "git+https://kislakiruben@github.com/kislakiruben/parsecnp.git",
  "keywords": ["cnp", "parser", "javascript"],
  "author": "Ruben Kislaki",
  "license": "MIT",
  "bugs": { "url": "https://github.com/kislakiruben/parsecnp/issues" },
  "homepage": "https://github.com/kislakiruben/parsecnp#readme",
  "devDependencies": {
    "@babel/core": "^7.20.2",
    "@babel/preset-env": "^7.20.2",
    "@rollup/plugin-babel": "^6.0.3",
    "rollup": "^3.4.0",
    "rollup-plugin-terser": "^7.0.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9"
  },
  "packageManager": "pnpm@10.8.1"
}
