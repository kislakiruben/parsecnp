{
  "name": "parsecnp",
  "version": "0.1.9",
  "description": "'Parser' pentru cod numeric personal (CNP)",
  "type": "module",
  "files": ["dist"],
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "TZ='Europe/London' vitest run",
    "typecheck": "tsc --noEmit",
    "coverage": "TZ='Europe/London' vitest run --coverage",
    "prepare": "pnpm build"
  },
  "repository": "git+https://kislakiruben@github.com/kislakiruben/parsecnp.git",
  "keywords": [
    "cnp",
    "parser",
    "javascript"
  ],
  "author": "Ruben Kislaki",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kislakiruben/parsecnp/issues"
  },
  "homepage": "https://github.com/kislakiruben/parsecnp#readme",
  "devDependencies": {
    "tsdown": "^0.22.3",
    "typescript": "^5.9.3",
    "unrun": "^0.3.1",
    "vitest": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9"
  },
  "packageManager": "pnpm@10.8.1"
}
